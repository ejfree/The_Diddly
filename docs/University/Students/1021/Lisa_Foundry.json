    {
      "name": "Double Slice",
      "type": "feat",
      "img": "systems/pf2e/icons/default-icons/feat.svg",
      "system": {
        "description": {
          "value": "<p><strong>Requirements</strong> You are wielding two weapons, each in a different hand.<br>You lunge with both weapons at once. Make two Strikes, one with each weapon, each using your current multiple attack penalty. If both attacks hit the same creature, combine their damage for the purpose of resistances and weaknesses. If the second weapon has the agile trait, its MAP is the same as the first weapon.</p>"
        },
        "featType": { "value": "class" },
        "level": { "value": 1 },
        "traits": { "value": ["fighter", "flourish"] },
        "actionType": { "value": "action" },
        "actions": { "value": 2 },
        "prerequisites": { "value": [] }
      }
    },
    {
      "name": "Twin Parry",
      "type": "feat",
      "img": "systems/pf2e/icons/default-icons/feat.svg",
      "system": {
        "description": {
          "value": "<p>You use your two weapons to parry attacks. You gain a +1 circumstance bonus to AC until the start of your next turn, or a +2 circumstance bonus if either weapon has the parry trait.</p>"
        },
        "featType": { "value": "class" },
        "level": { "value": 4 },
        "traits": { "value": ["fighter"] },
        "actionType": { "value": "action" },
        "actions": { "value": 1 },
        "prerequisites": { "value": [] }
      }
    },
    {
      "name": "Agile Grace",
      "type": "feat",
      "img": "systems/pf2e/icons/default-icons/feat.svg",
      "system": {
        "description": {
          "value": "<p>Your graceful moves with agile weapons are beyond compare. Your multiple attack penalty with agile weapons is –3 on your second attack and –6 on each subsequent attack.</p>"
